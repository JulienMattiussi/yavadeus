# Shared PUBLIC configuration (committed). No secrets here.
# Secrets (e.g. GITHUB_TOKEN for `make fetch`) stay as real shell env vars,
# or go in .env.local (git-ignored). Real env vars override these values.

# GitHub account whose non-fork repos make up the catalog.
GITHUB_USER=JulienMattiussi

# npm maintainer handle: a repo's package is linked only if published under it.
NPM_USER=yavadeus

# Production site URL (canonical URLs, footer link, etc.).
SITE_URL=https://yavadeus.dev

# Footer social links (public). Omit a line to hide that footer entry.
LINKEDIN_URL=https://www.linkedin.com/in/julien-mattiussi-08a531169/
BLOG_URL=https://marmelab.com/blog/authors/julienm
