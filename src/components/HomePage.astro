---
import { getCollection } from 'astro:content';
import { CATEGORIES, type Category } from '../data/projects';
import type { Lang, UIKey } from '../i18n/ui';
import { otherLangPath, useTranslations } from '../i18n/ui';
import Footer from './Footer.astro';
import Layout from '../layouts/Layout.astro';
import ProjectCard from './ProjectCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const all = await getCollection('projects');
const projects = all
  .map((e) => e.data)
  .sort((a, b) => (b.createdAt ?? '').localeCompare(a.createdAt ?? ''));

const byCategory = (cat: Category) => projects.filter((p) => p.category === cat);
---

<Layout lang={lang}>
  <div class="topbar-bar">
    <nav class="topbar wrap" aria-label={t('a11y.nav')}>
      <span class="prompt mono" aria-hidden="true">~/projects</span>
      <a
        class="lang mono"
        href={otherLangPath(lang)}
        hreflang={lang === 'fr' ? 'en' : 'fr'}
        aria-label={t('lang.switch.aria')}
      >
        {t('lang.switch')}
      </a>
    </nav>
  </div>

  <header class="hero wrap">
    <h1 class="logo mono">
      <span class="sigil" aria-hidden="true">$</span>
      {t('site.title')}<span class="caret" aria-hidden="true">_</span>
    </h1>
    <p class="tagline">{t('site.tagline')}</p>
    <p class="intro">{t('site.intro')}</p>
  </header>

  <main id="content" class="wrap" tabindex="-1">
    <div class="toolbar" data-toolbar>
      <label class="search-box">
        <span class="search-prompt mono" aria-hidden="true">/</span>
        <input
          id="project-search"
          type="search"
          class="mono"
          placeholder={`${t('search.placeholder')} (${projects.length} ${t('count.existing')})`}
          autocomplete="off"
          aria-label={t('search.placeholder')}
        />
      </label>
      <div class="sort" role="group" aria-label={t('view.label')}>
        <span class="sort-label mono">
          <span class="label-full">{t('view.label')}</span>
          <span class="label-short">{t('view.label.short')}</span>
        </span>
        <button type="button" class="sort-btn mono" data-view="categories" aria-pressed="true">
          {t('view.categories')}
        </button>
        <button type="button" class="sort-btn mono" data-view="created" aria-pressed="false">
          {t('sort.created')}
        </button>
        <button type="button" class="sort-btn mono" data-view="updated" aria-pressed="false">
          {t('sort.updated')}
        </button>
      </div>
    </div>

    <div id="view-categories">
      {
        CATEGORIES.map((cat) => {
          const items = byCategory(cat);
          if (items.length === 0) return null;
          return (
            <section class="category" data-category={cat} aria-labelledby={`cat-${cat}`}>
              <div class="cat-head">
                <h2 id={`cat-${cat}`} class="cat-title mono">
                  <span class="hash">#</span> {t(`cat.${cat}` as UIKey)}
                  <span class="cat-count" data-total={items.length}>
                    {items.length} {t('count.projects')}
                  </span>
                </h2>
                <p class="cat-desc">{t(`cat.${cat}.desc` as UIKey)}</p>
              </div>
              {cat === 'delires' ? (
                <div class="delires-gate">
                  <input type="checkbox" id="openmind" class="openmind-toggle" />
                  <div class="grid blurable" data-grid={cat}>
                    {items.map((project) => (
                      <ProjectCard project={project} lang={lang} />
                    ))}
                  </div>
                  <label class="openmind-switch" for="openmind">
                    <span class="openmind-control">
                      <span class="toggle" aria-hidden="true">
                        <span class="toggle-knob">
                          <span class="openmind-emoji">🤪</span>
                        </span>
                      </span>
                      <span class="toggle-text mono">{t('delires.gate')}</span>
                    </span>
                  </label>
                </div>
              ) : (
                <div class="grid" data-grid={cat}>
                  {items.map((project) => (
                    <ProjectCard project={project} lang={lang} />
                  ))}
                </div>
              )}
            </section>
          );
        })
      }
    </div>

    <div id="view-timeline" data-unknown-year={t('year.unknown')} hidden></div>

    <p id="search-empty" class="empty mono" hidden>{t('search.empty')}</p>
  </main>

  <Footer lang={lang} />
</Layout>

<script>
  import {
    normalizeText,
    textMatches,
    uniqueYearsDesc,
    yearFromTimestamp,
  } from '../scripts/home-view';

  // Progressive enhancement: client-side search + view switching.
  // Views: "categories" (server-rendered rubrics, default) and two global
  // timelines grouped by year ("created" / "updated"). Without JS, the
  // categories view stays visible and search/timeline are simply unavailable.
  const search = document.getElementById('project-search') as HTMLInputElement | null;
  const viewButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view]'));
  const categoriesView = document.getElementById('view-categories');
  const timelineView = document.getElementById('view-timeline');
  const empty = document.getElementById('search-empty');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const unknownYear = timelineView?.dataset.unknownYear ?? '?';

  // Remember each card's home grid and original order, to restore categories.
  cards.forEach((card, i) => {
    card.dataset.order = String(i);
  });

  // Keep sticky offsets in sync with the real bar heights (they change when the
  // toolbar wraps on narrow screens), so stacked sticky headers never overlap.
  const topbar = document.querySelector<HTMLElement>('.topbar-bar');
  const toolbar = document.querySelector<HTMLElement>('.toolbar');
  function measureSticky() {
    const root = document.documentElement.style;
    if (topbar) root.setProperty('--topbar-h', `${topbar.offsetHeight}px`);
    if (toolbar) root.setProperty('--toolbar-h', `${toolbar.offsetHeight}px`);
  }
  measureSticky();
  window.addEventListener('resize', measureSticky);
  if (document.fonts?.ready) document.fonts.ready.then(measureSticky);

  // Flag a category header as `stuck` once it reaches the sticky line, so its
  // description can collapse on mobile.
  const catHeads = Array.from(document.querySelectorAll<HTMLElement>('.cat-head'));
  let stuckTicking = false;
  function updateStuck() {
    stuckTicking = false;
    const line = (topbar?.offsetHeight ?? 0) + (toolbar?.offsetHeight ?? 0);
    for (const h of catHeads)
      h.classList.toggle('stuck', h.getBoundingClientRect().top <= line + 1);
  }
  window.addEventListener(
    'scroll',
    () => {
      if (!stuckTicking) {
        stuckTicking = true;
        requestAnimationFrame(updateStuck);
      }
    },
    { passive: true },
  );
  updateStuck();

  // "Open-minded mode" gate on the délires rubric: blurred until enabled,
  // remembered for the tab session. inert keeps blurred cards out of tab + SR.
  const openmind = document.getElementById('openmind') as HTMLInputElement | null;
  const blurable = document.querySelector<HTMLElement>('.blurable');
  if (openmind && blurable) {
    const KEY = 'yavadeus:openmind';
    const syncOpenmind = () => {
      blurable.inert = !openmind.checked;
      try {
        if (openmind.checked) sessionStorage.setItem(KEY, '1');
        else sessionStorage.removeItem(KEY);
      } catch {
        /* sessionStorage unavailable: degrade to per-page state */
      }
    };
    try {
      if (sessionStorage.getItem(KEY) === '1') openmind.checked = true;
    } catch {
      /* ignore */
    }
    syncOpenmind();
    openmind.addEventListener('change', syncOpenmind);
  }

  type View = 'categories' | 'created' | 'updated';
  let view: View = 'categories';

  const matches = (card: HTMLElement, query: string) =>
    textMatches(card.dataset.search ?? '', query);

  const yearOf = (card: HTMLElement, key: View) =>
    yearFromTimestamp(Number(card.dataset[key] ?? 0));

  function renderCategories(query: string) {
    if (!categoriesView) return;
    for (const card of cards) {
      const grid = categoriesView.querySelector<HTMLElement>(
        `[data-grid="${card.dataset.category}"]`,
      );
      grid?.appendChild(card);
    }
    for (const grid of categoriesView.querySelectorAll<HTMLElement>('.grid')) {
      Array.from(grid.children)
        .sort(
          (a, b) =>
            Number((a as HTMLElement).dataset.order) - Number((b as HTMLElement).dataset.order),
        )
        .forEach((card) => grid.appendChild(card));
    }
    for (const section of categoriesView.querySelectorAll<HTMLElement>('.category')) {
      let count = 0;
      section.querySelectorAll<HTMLElement>('.card').forEach((c) => {
        const ok = matches(c, query);
        c.hidden = !ok;
        if (ok) count++;
      });
      section.hidden = count === 0;
      const countEl = section.querySelector<HTMLElement>('.cat-count');
      if (countEl) {
        const total = Number(countEl.dataset.total ?? count);
        const unit = (countEl.textContent ?? '').trim().replace(/^[\d/]+\s*/, '');
        countEl.textContent = `${count < total ? `${count}/${total}` : total} ${unit}`.trimEnd();
      }
    }
    categoriesView.hidden = false;
    if (timelineView) timelineView.hidden = true;
  }

  function renderTimeline(key: View, query: string) {
    if (!timelineView) return;
    timelineView.textContent = '';
    if (categoriesView) categoriesView.hidden = true;
    timelineView.hidden = false;

    const visibleCards = cards.filter((c) => matches(c, query));
    const years = uniqueYearsDesc(visibleCards.map((c) => yearOf(c, key)));

    for (const year of years) {
      const group = visibleCards
        .filter((c) => yearOf(c, key) === year)
        .sort((a, b) => Number(b.dataset[key] ?? 0) - Number(a.dataset[key] ?? 0));
      if (group.length === 0) continue;

      const section = document.createElement('section');
      section.className = 'year-group';
      const head = document.createElement('h2');
      head.className = 'year-title mono';
      head.innerHTML =
        `<span class="year-num">${year === 0 ? unknownYear : year}</span>` +
        `<span class="year-count">${group.length}</span>`;
      const grid = document.createElement('div');
      grid.className = 'grid';
      for (const card of group) {
        card.hidden = false;
        grid.appendChild(card);
      }
      section.append(head, grid);
      timelineView.appendChild(section);
    }
  }

  function apply() {
    const query = normalizeText(search?.value.trim() ?? '');
    if (view === 'categories') renderCategories(query);
    else renderTimeline(view, query);
    if (empty) empty.hidden = cards.some((card) => matches(card, query));
  }

  search?.addEventListener('input', apply);
  for (const button of viewButtons) {
    button.addEventListener('click', () => {
      view = (button.dataset.view as View) ?? 'categories';
      for (const other of viewButtons) {
        other.setAttribute('aria-pressed', String(other === button));
      }
      apply();
    });
  }

  apply();
  search?.focus({ preventScroll: true });
</script>

<style>
  .topbar-bar {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--topbar-h);
    font-size: 0.85rem;
  }
  .prompt {
    color: var(--text-faint);
  }

  .hero {
    padding-top: 2.5rem;
    padding-bottom: 2rem;
  }
  .lang {
    color: var(--text-dim);
    border: 1px solid var(--line-strong);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    transition:
      color var(--transition),
      border-color var(--transition);
  }
  .lang:hover {
    color: var(--accent);
    border-color: var(--accent-dim);
  }

  .logo {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .sigil {
    color: var(--accent);
  }
  .caret {
    color: var(--accent);
    animation: blink 1.1s steps(1) infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .caret {
      animation: none;
    }
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--text);
    margin: 0.6rem 0 0.2rem;
  }
  .intro {
    color: var(--text-dim);
    margin: 0;
    max-width: 48ch;
  }

  .toolbar {
    position: sticky;
    top: var(--topbar-h);
    z-index: 20;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem 1.2rem;
    padding: 0.7rem 0.9rem;
    margin-bottom: 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1 1 240px;
  }
  .search-prompt {
    color: var(--accent);
    font-size: 1rem;
  }
  #project-search {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    color: var(--text);
    font-size: 0.95rem;
    padding: 0.2rem 0;
  }
  #project-search::placeholder {
    color: var(--text-faint);
  }
  #project-search:focus {
    outline: none;
  }
  .search-box:focus-within {
    border-bottom: 1px solid var(--accent-dim);
  }

  .sort {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .sort-label {
    color: var(--text-faint);
    font-size: 0.78rem;
    margin-right: 0.1rem;
  }
  .label-short {
    display: none;
  }
  .sort-btn {
    cursor: pointer;
    font: inherit;
    font-size: 0.8rem;
    color: var(--text-dim);
    background: transparent;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
    transition:
      color var(--transition),
      border-color var(--transition),
      background var(--transition);
  }
  .sort-btn:hover {
    color: var(--text);
  }
  .sort-btn[aria-pressed='true'] {
    color: var(--accent);
    border-color: var(--accent-dim);
    background: var(--accent-glow);
  }

  .empty {
    color: var(--text-dim);
    text-align: center;
    padding: 3rem 0;
  }

  /*
   * "Open-minded mode": délires cards are blurred until a real toggle switch is
   * flipped. The 🤪 emoji rides the knob, greyscale when off, colored when on.
   * Pure CSS (sibling selectors) so it works without JS; JS adds inert + memory.
   */
  .blurable {
    filter: blur(8px);
    pointer-events: none;
    user-select: none;
    transition: filter 0.3s ease;
  }
  .openmind-toggle:checked ~ .blurable {
    filter: none;
    pointer-events: auto;
    user-select: auto;
  }
  /* visually hidden but focusable */
  .openmind-toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: 0;
    opacity: 0;
  }
  .delires-gate {
    position: relative;
  }
  .openmind-switch {
    position: absolute;
    inset: 0;
    z-index: 5;
    padding: 1.5rem;
    cursor: pointer;
    user-select: none;
    text-align: center;
    background: color-mix(in srgb, var(--bg) 55%, transparent);
    transition: opacity 0.35s ease 0.45s;
  }
  /* Track the viewport (just under the sticky headers) so the toggle is always
     reachable, instead of stranded at the vertical center of a tall grid. */
  .openmind-control {
    position: sticky;
    top: calc(var(--topbar-h) + var(--toolbar-h) + 1.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }
  .toggle {
    position: relative;
    flex: none;
    width: 9rem;
    height: 4.4rem;
    border-radius: 999px;
    background: var(--bg);
    border: 2px solid var(--line-strong);
    transition:
      background var(--transition),
      border-color var(--transition);
  }
  .toggle-knob {
    position: absolute;
    top: 50%;
    left: 0.4rem;
    transform: translateY(-50%);
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 50%;
    background: var(--bg-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: left 0.32s cubic-bezier(0.5, 1.7, 0.5, 1);
  }
  .openmind-emoji {
    font-size: 2.3rem;
    line-height: 1;
    filter: grayscale(1) opacity(0.5);
    transition: filter 0.32s ease;
  }
  .toggle-text {
    font-weight: 600;
    font-size: clamp(1.2rem, 3vw, 1.7rem);
    color: var(--text-dim);
    transition: color var(--transition);
  }
  .openmind-switch:hover .toggle {
    border-color: var(--cat-delires);
  }
  .openmind-toggle:focus-visible ~ .openmind-switch .toggle {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .openmind-toggle:checked ~ .openmind-switch .toggle {
    background: color-mix(in srgb, var(--cat-delires) 22%, var(--bg));
    border-color: var(--cat-delires);
  }
  .openmind-toggle:checked ~ .openmind-switch .toggle-knob {
    left: calc(100% - 4rem);
  }
  .openmind-toggle:checked ~ .openmind-switch .openmind-emoji {
    filter: none;
  }
  .openmind-toggle:checked ~ .openmind-switch .toggle-text {
    color: var(--cat-delires);
  }
  /* Once on, the overlay fades away (after the slide plays) and never returns. */
  .openmind-toggle:checked ~ .openmind-switch {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.35s ease 0.45s,
      visibility 0s linear 0.8s;
  }

  .category {
    margin: 3rem 0;
  }
  .cat-head {
    position: sticky;
    top: calc(var(--topbar-h) + var(--toolbar-h));
    z-index: 10;
    margin-bottom: 1.1rem;
    padding: 0.6rem 0 0.5rem;
    background: var(--bg);
  }
  .cat-title {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 1.4rem;
    color: var(--text);
  }
  .category[data-category='jeux'] .hash {
    color: var(--cat-jeux);
  }
  .category[data-category='outils'] .hash {
    color: var(--cat-outils);
  }
  .category[data-category='delires'] .hash {
    color: var(--cat-delires);
  }
  .category[data-category='marmelab'] .hash {
    color: var(--cat-marmelab);
  }
  .cat-count {
    font-size: 0.75rem;
    color: var(--text-faint);
    font-weight: 400;
  }
  .cat-desc {
    color: var(--text-dim);
    margin: 0.35rem 0 0;
    font-size: 0.95rem;
  }

  @media (max-width: 560px) {
    .hero {
      padding-top: 1.75rem;
    }
    .toolbar {
      flex-direction: column;
      align-items: stretch;
      gap: 0.7rem;
    }
    .search-box {
      flex: none;
    }
    .label-full {
      display: none;
    }
    .label-short {
      display: inline;
    }
    .sort {
      flex-wrap: wrap;
    }
    .sort-btn {
      flex: 1 1 auto;
      text-align: center;
    }
    .category,
    .year-group {
      margin: 2rem 0;
    }
    .cat-head.stuck .cat-desc {
      display: none;
    }
  }
</style>
